QUERY 
Comparison Selectors 
1. Greater Than ($gt) 
db.students.find({ marks: { $gt: 70 } }) 
// Finds students whose marks are greater than 70 
2. Less Than ($lt) 
db.students.find({ marks: { $lt: 70 } }) 
// Finds students whose marks are less than 70 
3. Greater Than or Equal ($gte) 
db.students.find({ age: { $gte: 22 } }) 
// Finds students whose age is greater than or equal to 22 
4. Not Equal ($ne) 
db.students.find({ department: { $ne: "CSE" } }) 
// Finds students whose department is not CSE 
